.page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}
.loading-hint {
  text-align: center;
  color: #a39e96;
  font-size: 26rpx;
  margin-top: 120rpx;
}
.toolbar {
  display: flex;
  gap: 16rpx;
  margin: 6rpx 28rpx 14rpx;
}
.chip {
  flex: 1;
  text-align: center;
  font-size: 25rpx;
  line-height: 1.3;
  padding: 16rpx 0;
  border-radius: 40rpx;
  background: #fff;
  color: #1b3a5f;
  border: 1rpx solid #d8e0ea;
}
.chip.primary {
  background: #1b3a5f;
  color: #fff;
  border-color: #1b3a5f;
  box-shadow: 0 4rpx 12rpx rgba(27, 58, 95, 0.22);
}
.chip.mute {
  color: #b8b3aa;
  border-color: #ece7e0;
}
.chip.gold {
  color: #c8860a;
  border-color: #eccf8f;
  background: #fffaf0;
}
.go-hint {
  margin: 0 28rpx 14rpx;
  font-size: 23rpx;
  color: #9a948b;
  text-align: center;
}
.saved-flag {
  margin-left: 8rpx;
  color: #e6a23c;
  font-size: 22rpx;
}

/* 品牌横幅 */
.banner {
  position: relative;
  overflow: hidden;
  padding: 40rpx 32rpx 36rpx;
  background: linear-gradient(135deg, #1b3a5f 0%, #2c5688 100%);
}
.banner-tex {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}
.brand {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}
.logo {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
}
.brand-txt {
  flex: 1;
  margin-left: 22rpx;
}
.brand-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}
.brand-sub {
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 6rpx;
}
.banner-btn {
  background: #fff;
  color: #1b3a5f;
  font-size: 26rpx;
  font-weight: 500;
  padding: 14rpx 30rpx;
  border-radius: 40rpx;
}
.banner-btn.busy {
  opacity: 0.6;
}
.meta {
  font-size: 24rpx;
  color: #8a8580;
  margin: 18rpx 32rpx 4rpx;
}

/* 列表卡片 */
.list {
  padding: 16rpx 24rpx;
}
.card {
  position: relative;
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.04);
}
.card.high::after {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #1b3a5f;
}
.card.sel {
  box-shadow: 0 0 0 2rpx #1b3a5f;
}
.pick {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d6d0c8;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 38rpx;
  margin-right: 22rpx;
  margin-top: 4rpx;
}
.pick.on {
  background: #1b3a5f;
  border-color: #1b3a5f;
}
.body {
  flex: 1;
  min-width: 0;
}
.row1 {
  display: flex;
  align-items: center;
}
.name {
  flex: 1;
  font-size: 31rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.35;
  margin-right: 14rpx;
}
.sub {
  font-size: 25rpx;
  color: #8a8580;
  margin-top: 10rpx;
}
.contact {
  font-size: 26rpx;
  color: #3a3a3a;
  margin-top: 12rpx;
  word-break: break-all;
}
.contact.muted {
  color: #c0bbb2;
}

