.page {
  padding: 24rpx 28rpx calc(140rpx + env(safe-area-inset-bottom));
}
.head {
  display: flex;
  align-items: center;
  padding: 8rpx 4rpx 12rpx;
}
.mini-logo {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}
.intro {
  font-size: 25rpx;
  color: #8a8580;
  margin: 4rpx 6rpx 20rpx;
  line-height: 1.5;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx 28rpx;
  box-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.04);
}
.field-label {
  font-size: 25rpx;
  color: #8a8580;
  margin: 22rpx 0 8rpx;
}
.seg {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #f4f2ef;
  color: #6a655f;
  border: 1rpx solid #ece7e0;
}
.seg-item.on {
  background: #e9eef6;
  color: #1b3a5f;
  border-color: #1b3a5f;
  font-weight: 600;
}
.btn-wrap {
  margin-top: 26rpx;
}
.tip {
  font-size: 23rpx;
  color: #a39e96;
  margin: 20rpx 6rpx;
  line-height: 1.5;
}
