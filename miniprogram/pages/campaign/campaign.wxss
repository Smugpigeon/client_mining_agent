.page {
  padding: 24rpx 28rpx calc(140rpx + env(safe-area-inset-bottom));
}
.head {
  display: flex;
  align-items: center;
  padding: 8rpx 4rpx 16rpx;
}
.mini-logo {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}
.empty-wrap {
  margin-top: 160rpx;
}
.hint {
  font-size: 26rpx;
  color: #5a5650;
  margin: 6rpx 4rpx 20rpx;
}
.hint .num {
  color: #1b3a5f;
  font-weight: 600;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx 28rpx;
  box-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.04);
}
.field-label {
  font-size: 25rpx;
  color: #8a8580;
  margin: 22rpx 0 8rpx;
}
.prod-card {
  margin-top: 18rpx;
  padding-bottom: 14rpx;
}
.prow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 6rpx;
  border-top: 1rpx solid #f0ece6;
}
.prow:first-of-type {
  border-top: none;
}
.prow-name {
  font-size: 27rpx;
  color: #1a1a1a;
}
.prow.on .prow-name {
  color: #1b3a5f;
  font-weight: 600;
}
.check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #cfcabf;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 40rpx;
}
.check.on {
  background: #1b3a5f;
  border-color: #1b3a5f;
}
.prod-tip {
  font-size: 23rpx;
  color: #a39e96;
  margin: 18rpx 6rpx 0;
  line-height: 1.5;
}
.tip {
  font-size: 23rpx;
  color: #a39e96;
  margin: 18rpx 6rpx;
  line-height: 1.5;
}
.btn-row {
  display: flex;
  gap: 18rpx;
  margin-top: 8rpx;
}
.btn-row > t-button {
  flex: 1;
}
.export-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 10rpx;
}
.results {
  margin-top: 28rpx;
}
.results-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0 4rpx 14rpx;
}
.rcard {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}
.rtop {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.rto {
  font-size: 26rpx;
  color: #1a1a1a;
  word-break: break-all;
}
.badge {
  font-size: 26rpx;
  font-weight: 600;
}
.badge.ok {
  color: #2ba471;
}
.badge.bad {
  color: #d54941;
}
.rprev {
  font-size: 24rpx;
  color: #6a655f;
  margin-top: 12rpx;
  white-space: pre-wrap;
  line-height: 1.5;
}
.rerr {
  font-size: 24rpx;
  color: #d54941;
  margin-top: 10rpx;
}
